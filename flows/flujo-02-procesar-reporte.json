    {
      "id": "node-validar-completitud",
      "name": "Validar completitud",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3320, 400],
      "parameters": {
        "jsCode": "const rawContent = $('LLM Extracción').first().json.choices[0].message.content;\nconst extraccion = JSON.parse(rawContent);\nconst tipoEvento = extraccion.tipo_evento;\n\nconst camposObligatoriosPorTipo = {\n  labor:       ['lote_id', 'campos_extraidos.labor_tipo'],\n  insumo:      ['lote_id', 'campos_extraidos.producto'],\n  plaga:       ['lote_id', 'campos_extraidos.plaga_tipo'],\n  clima:       ['campos_extraidos.clima_tipo'],\n  cosecha:     ['lote_id', 'campos_extraidos.cantidad', 'campos_extraidos.unidad'],\n  gasto:       ['campos_extraidos.concepto', 'campos_extraidos.monto'],\n  observacion: ['campos_extraidos.texto_libre'],\n  nota_libre:  ['campos_extraidos.texto_libre']\n};\n\nconst obligatorios = camposObligatoriosPorTipo[tipoEvento] ?? [];\nconst camposFaltantes = obligatorios.filter(campo => {\n  const parts = campo.split('.');\n  let val = extraccion;\n  for (const part of parts) val = val?.[part];\n  return val === null || val === undefined;\n});\n\nconst resultado = camposFaltantes.length === 0 ? 'completo' :\n  (extraccion.requiere_clarificacion ? 'incompleto' : 'fallback_nota_libre');\n\nreturn [{\n  json: {\n    ...$('Preparar texto final').first().json,\n    extraccion,\n    resultado,\n    campos_faltantes: camposFaltantes,\n    tipo_evento: tipoEvento\n  }\n}];"
      }
