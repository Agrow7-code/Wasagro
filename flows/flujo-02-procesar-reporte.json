    },
    {
      "id": "node-cerrar-sesion-pendiente",
      "name": "Cerrar sesión pendiente como nota_libre",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [900, 260],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH sesion_cerrada AS (\n  UPDATE sesiones_activas\n  SET status = 'fallback_nota_libre', updated_at = NOW()\n  WHERE phone = $1\n    AND status = 'active'\n    AND tipo_sesion = 'reporte'\n    AND expires_at > NOW()\n  RETURNING session_id, contexto_parcial\n)\nINSERT INTO eventos_campo (finca_id, tipo_evento, status, datos_evento, descripcion_raw, confidence_score, requiere_validacion)\nSELECT $2, 'nota_libre', 'requires_review',\n  COALESCE(sc.contexto_parcial, '{}')::jsonb,\n  'Sesión anterior cerrada por nuevo mensaje',\n  0.0, true\nFROM sesion_cerrada sc\nWHERE sc.session_id IS NOT NULL\nRETURNING id;",
        "additionalFields": {
          "queryParams": "={{ [$('Entrada desde flujo-01').first().json.phone, $('Entrada desde flujo-01').first().json.finca_id] }}"
        }
      },
      "credentials": {"postgres": {"name": "PLACEHOLDER: Supabase Postgres (service_role)"}},
