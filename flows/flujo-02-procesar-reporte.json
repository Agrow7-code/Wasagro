      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT session_id, clarification_count, contexto_parcial, tipo_sesion\nFROM sesiones_activas\nWHERE phone = $1\n  AND status = 'active'\n  AND expires_at > NOW()\nORDER BY created_at DESC\nLIMIT 1;",
        "additionalFields": {
          "queryParams": "={{ [$('Entrada desde flujo-01').first().json.phone] }}"
        }
      },
