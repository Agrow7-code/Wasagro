    {
      "id": "node-preparar-texto",
      "name": "Preparar texto final",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 400],
      "parameters": {
        "jsCode": "const tipoMensaje = $('Entrada desde flujo-01').first().json.tipo_mensaje;\nconst sesion = $('Buscar sesión activa').first().json;\n\nlet textoFinal = '';\nif (tipoMensaje === 'audio') {\n  textoFinal = $('Post-corrección STT').first().json?.choices?.[0]?.message?.content\n    ?? $('STT Transcripción').first().json?.text ?? '';\n} else if (tipoMensaje === 'image') {\n  const visionRaw = $('Vision Análisis').first().json?.choices?.[0]?.message?.content ?? '{}';\n  const caption = $('Entrada desde flujo-01').first().json?.content?.caption ?? '';\n  textoFinal = (caption ? caption + ' — ' : '') + visionRaw;\n} else {\n  textoFinal = $('Entrada desde flujo-01').first().json?.contenido_raw ?? '';\n}\n\nconst esContinuacion = !!sesion.contexto_parcial?.texto_previo;\nif (esContinuacion) {\n  textoFinal = `Contexto previo: ${sesion.contexto_parcial.texto_previo}\\nNueva info: ${textoFinal}`;\n}\n\nreturn [{\n  json: {\n    ...$('Entrada desde flujo-01').first().json,\n    texto_final: textoFinal,\n    es_continuacion: esContinuacion,\n    __t0_extraccion: new Date().toISOString()\n  }\n}];"
      },
      "notes": "Captura __t0_extraccion para span de LLM Extracción (R4)."
    },
