    {
      "id": "node-persistir-evento",
      "name": "Persistir evento",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [4200, 500],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH evento_insertado AS (\n  INSERT INTO eventos_campo\n    (finca_id, lote_id, tipo_evento, status, datos_evento, descripcion_raw,\n     confidence_score, requiere_validacion, fecha_evento, created_by, mensaje_id)\n  VALUES ($1, $2, $3, $4, $5::jsonb, $6, $7, $8, CURRENT_DATE, $9, $10)\n  RETURNING id\n)\nUPDATE mensajes_entrada\n  SET status = 'processed',\n      evento_id = (SELECT id FROM evento_insertado),\n      updated_at = NOW()\nWHERE id = $10\nRETURNING (SELECT id FROM evento_insertado) AS evento_id;",
        "additionalFields": {
          "queryParams": "={{ [\n  $json.finca_id,\n  $json.extraccion.lote_id ?? null,\n  $json.extraccion.tipo_evento,\n  ($json.resultado === 'fallback_nota_libre' || $json.action === 'fallback') ? 'requires_review' : 'complete',\n  JSON.stringify($json.extraccion.campos_extraidos ?? {}),\n  $json.contenido_raw,\n  $json.extraccion.confidence_score ?? 0.0,\n  ($json.extraccion.confidence_score ?? 0) < 0.5,\n  $json.user_id,\n  $json.mensaje_entrada_id\n] }}"
        }
      },
      "credentials": {"postgres": {"name": "PLACEHOLDER: Supabase Postgres (service_role)"}},
      "notes": "P5: descripcion_raw siempre persistido."
    },
