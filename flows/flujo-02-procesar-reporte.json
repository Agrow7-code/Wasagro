      "position": [3760, 300],
      "parameters": {
        "jsCode": "// R2: decisión basada en clarification_count de la DB.\nconst { extraccion, campos_faltantes } = $input.first().json;\nconst sesion = $('Buscar sesión activa').first().json;\nconst clarificationCount = sesion.clarification_count ?? 0;\n\nif (clarificationCount >= 2) {\n  return [{ json: { action: 'fallback', extraccion, campos_faltantes, clarification_count: clarificationCount } }];\n}\n\nconst campoPregunta = campos_faltantes.includes('lote_id') ? 'lote_id' : campos_faltantes[0];\nconst pregunta = extraccion.pregunta_sugerida ??\n  (campoPregunta === 'lote_id' ? '¿En qué lote hiciste eso?' : `¿Podés decirme el ${campoPregunta}?`);\n\nreturn [{\n  json: {\n    action: 'clarify',\n    pregunta,\n    session_id: sesion.session_id,\n    clarification_count_actual: clarificationCount,\n    extraccion,\n    campos_faltantes\n  }\n}];"
      },
      "notes": "R2: lee clarification_count de DB. Solo lógica de decisión, sin SQL."
    },
    {
      "id": "node-if-clarificar",
      "name": "If: ¿Clarificar o fallback?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [3980, 300],
      "parameters": {
        "conditions": {
          "string": [{"value1": "={{ $json.action }}", "operation": "equal", "value2": "clarify"}]
        }
      }
    },
    {
      "id": "node-upsert-sesion-clarificacion",
      "name": "Upsert sesión clarificación",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [4200, 200],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH sesion_update AS (\n  UPDATE sesiones_activas\n  SET\n    clarification_count = clarification_count + 1,\n    contexto_parcial = $2::jsonb,\n    ultimo_mensaje_at = NOW(),\n    expires_at = NOW() + INTERVAL '30 minutes'\n  WHERE phone = $1\n    AND status = 'active'\n    AND expires_at > NOW()\n  RETURNING session_id, clarification_count\n)\nINSERT INTO sesiones_activas (phone, tipo_sesion, clarification_count, contexto_parcial, expires_at)\nSELECT $1, 'reporte', 1, $2::jsonb, NOW() + INTERVAL '30 minutes'\nWHERE NOT EXISTS (SELECT 1 FROM sesion_update)\nRETURNING session_id, clarification_count;",
        "additionalFields": {
          "queryParams": "={{ [\n  $('Entrada desde flujo-01').first().json.phone,\n  JSON.stringify({ texto_previo: $('Preparar texto final').first().json.texto_final, extraccion_parcial: $json.extraccion })\n] }}"
        }
      },
      "credentials": {"postgres": {"name": "PLACEHOLDER: Supabase Postgres (service_role)"}},
      "notes": "R2 enforcement: UPDATE counter si sesión existe, INSERT con counter=1 si es nueva."
    },
    {
      "id": "node-enviar-pregunta-clarificacion",
