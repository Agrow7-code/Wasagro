{
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "buildCommand": "cd landing && npm run build",
  "outputDirectory": "landing/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/auth/$1"
    },
    {
      "source": "/webhook/(.*)",
      "destination": "/api/webhook/$1"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/(login|dashboard|gerente|exportadora|agricultor)(.*)",
      "destination": "/index.html"
    }
  ]
}
