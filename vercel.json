{
  "version": 2,
  "public": true,
  "outputDirectory": "landing/dist",
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api/auth/$1"
    },
    {
      "source": "/webhook/(.*)",
      "destination": "/api/webhook/$1"
    },
    {
      "source": "/(login|dashboard|gerente|exportadora|agricultor|brochure)(.*)",
      "destination": "/index.html"
    }
  ]
}
