{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "landing/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api"
    },
    {
      "source": "/webhook/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(login|dashboard|gerente|exportadora|agricultor)(.*)",
      "destination": "/landing/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/landing/$1"
    }
  ]
}
