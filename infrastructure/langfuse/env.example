# =============================================================================
# Wasagro — LangFuse Self-Hosted — Variables de entorno
# Copiar a .env y completar con valores reales.
# NUNCA commitear el archivo .env con valores reales.
# Uso: cp env.example .env
# =============================================================================

# URL publica donde corre LangFuse (sin trailing slash)
# Local: http://localhost:3000 | Produccion: https://langfuse.tu-dominio.com
LANGFUSE_HOST=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Secrets aleatorios — generar con: openssl rand -base64 32
NEXTAUTH_SECRET=REEMPLAZAR_CON_SECRET_ALEATORIO
SALT=REEMPLAZAR_CON_SALT_ALEATORIO

# Supabase Postgres
# Obtener en: Dashboard -> Settings -> Database -> Connection string -> URI
# Puerto: 5432 (NO usar 6543/pooler) | Agregar ?schema=langfuse al final
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?schema=langfuse

# Keys generadas en LangFuse UI DESPUES del primer login
# LangFuse UI -> Settings -> API Keys -> Create new key
LANGFUSE_PUBLIC_KEY=pk-lf-REEMPLAZAR
LANGFUSE_SECRET_KEY=sk-lf-REEMPLAZAR

# Configurar estas mismas 3 variables en n8n:
# n8n -> Settings -> Variables -> agregar LANGFUSE_PUBLIC_KEY, LANGFUSE_SECRET_KEY, LANGFUSE_HOST
